    Default="", Numeric=false,
    Callback=function(v) targetSkinName=v end
})
SkinGroupbox:AddButton({
    Text="🔓 Unlock & Add to Dropdown", DoubleClick=false,
    Func=function()
        if not modulesReady then Library:Notify({Title="⏳ Not Ready",Description="Still loading.",Time=3}) return end
        if targetSkinName=="" then Library:Notify({Title="❌ Empty",Description="Enter a cosmetic name!",Time=3}) return end
        local ok, err = pcall(function()
            local resolvedName = resolveCosmeticName(targetSkinName)
            if not resolvedName then
                Library:Notify({Title="❌ Not Found",Description="'"..targetSkinName.."' not found.",Time=5})
                return
            end
            if unlockedSkins[resolvedName] then
                Library:Notify({Title="Already Unlocked",Description=resolvedName.." already unlocked.",Time=3})
                return
            end
            applyPatches()
            unlockedSkins[resolvedName] = true
            if not Config.unlockedSkins then Config.unlockedSkins={} end
            table.insert(Config.unlockedSkins, resolvedName)
            saveConfig()
            table.insert(dropdownOptions, resolvedName)
            if SkinDropdown then
                pcall(function() SkinDropdown:SetValues(dropdownOptions) end)
            else
                SkinDropdown = SkinGroupbox:AddDropdown("SkinEquipDropdown", {
                    Text="Equip on held weapon", Values=dropdownOptions, Default=1,
                    Callback=function(value)
                        if not modulesReady then return end
                        local char = player.Character
                        local tool = char and char:FindFirstChildWhichIsA("Tool")
                        local wep = tool and tool.Name or ""
                        if wep == "" then
                            Library:Notify({Title="⚠️ No Weapon",Description="Equip a weapon first.",Time=4})
                            return
                        end
                        if value=="None" then
                            if equipped[wep] then equipped[wep]["Skin"]=nil if not next(equipped[wep]) then equipped[wep]=nil end end
                            if Config.equippedSkins and Config.equippedSkins[wep] then Config.equippedSkins[wep]["Skin"]=nil end
                            saveConfig() replicateWeapon()
                            Library:Notify({Title="Skin Removed",Description="Re-equip to see change.",Time=3})
                        else
                            local cosType=(CosmeticLibrary.Cosmetics[value] and CosmeticLibrary.Cosmetics[value].Type) or "Skin"
                            local skinData=cloneCosmetic(value,cosType,{})
                            if skinData then
                                equipped[wep]=equipped[wep] or {}
                                equipped[wep][cosType]=skinData
                                Config.equippedSkins=Config.equippedSkins or {}
                                Config.equippedSkins[wep]=Config.equippedSkins[wep] or {}
                                Config.equippedSkins[wep][cosType]=value
                                saveConfig() replicateWeapon()
                                Library:Notify({Title="✅ Equipped!",Description=value.." → "..wep,Time=4})
                            end
                        end
                    end
                })
            end
            Library:Notify({Title="🔓 Unlocked: "..resolvedName,Description="Pick from dropdown while holding weapon.",Time=5})
        end)
        if not ok then Library:Notify({Title="Error",Description=tostring(err),Time=6}) end
    end
})
