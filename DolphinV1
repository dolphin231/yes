            for _, skinName in ipairs(Config.unlockedSkins) do
                if CosmeticLibrary.Cosmetics[skinName] then
                    unlockedSkins[skinName] = true
                    if not table.find(dropdownOptions, skinName) then
                        table.insert(dropdownOptions, skinName)
                    end
                end
            end
            if next(unlockedSkins) then
                task.spawn(function()
                    while not modulesReady do task.wait(0.5) end
                    applyPatches()
                    if Config.equippedSkins then
                        for weaponName, cosmeticTypes in pairs(Config.equippedSkins) do
                            if type(cosmeticTypes) == "table" then
                                for cType, cName in pairs(cosmeticTypes) do
                                    if type(cName) == "string" and cName ~= "" then
                                        local skinData = cloneCosmetic(cName, cType, {})
                                        if skinData then
                                            equipped[weaponName] = equipped[weaponName] or {}
                                            equipped[weaponName][cType] = skinData
                                        end
                                    end
                                end
                            end
                        end
                        replicateWeapon()
                    end
                    print("✅ Config restored: " .. tostring(#Config.unlockedSkins) .. " skins.")
                end)
            end
        end

        -- Apply weapon unlock patches if it was saved as enabled
        if weaponUnlockEnabled then
            while not modulesReady do task.wait(0.5) end
            applyPatches()
        end

        modulesReady = true
        print("✅ Modules loaded.")
    end)
    if not ok then warn("[SkinChanger] Module load failed: " .. tostring(err)) end
end)

