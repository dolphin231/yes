-- ==================== HELPERS ====================
local cosmeticNameCache = nil
local function resolveCosmeticName(input)
    if not CosmeticLibrary then return nil end
    if CosmeticLibrary.Cosmetics[input] then return input end
    if not cosmeticNameCache then
        cosmeticNameCache = {}
        for name in pairs(CosmeticLibrary.Cosmetics) do
            cosmeticNameCache[name:lower()] = name
        end
    end
    return cosmeticNameCache[input:lower()]
end

local function cloneCosmetic(name, cosmeticType, options)
    if not CosmeticLibrary then return nil end
    local base = CosmeticLibrary.Cosmetics[name]
    if not base then return nil end
    local data = {}
    for key, value in pairs(base) do data[key] = value end
    data.Name = name
    data.Type = data.Type or cosmeticType
    data.Seed = data.Seed or math.random(1, 1000000)
    if EnumLibrary then
        local ok, enumId = pcall(EnumLibrary.ToEnum, EnumLibrary, name)
        if ok and enumId then data.Enum = enumId data.ObjectID = data.ObjectID or enumId end
    end
    if options and options.inverted ~= nil then data.Inverted = options.inverted end
    return data
end

