local function applyPatches()
    if patchesApplied then return end
    if not CosmeticLibrary or not DataController or not ItemLibrary then return end
    patchesApplied = true

    local origOwns = CosmeticLibrary.OwnsCosmetic
    local origOwnsNormally = CosmeticLibrary.OwnsCosmeticNormally
    local origOwnsUniversally = CosmeticLibrary.OwnsCosmeticUniversally
    local origOwnsForWeapon = CosmeticLibrary.OwnsCosmeticForWeapon

    CosmeticLibrary.OwnsCosmetic = function(self, inventory, name, weapon)
        if unlockedSkins[name] then return true end
        return origOwns(self, inventory, name, weapon)
    end
    CosmeticLibrary.OwnsCosmeticNormally = function(self, inventory, name)
        if unlockedSkins[name] then return true end
        return origOwnsNormally(self, inventory, name)
    end
    CosmeticLibrary.OwnsCosmeticUniversally = function(self, inventory, name)
        if unlockedSkins[name] then return true end
        return origOwnsUniversally(self, inventory, name)
    end
    CosmeticLibrary.OwnsCosmeticForWeapon = function(self, inventory, name, weapon)
        if unlockedSkins[name] then return true end
        return origOwnsForWeapon(self, inventory, name, weapon)
    end

    -- Single Get hook — CosmeticInventory + WeaponInventory (suspended during combat)
    local origGet = DataController.Get
    DataController.Get = function(self, key)
        local data = origGet(self, key)
        if key == "CosmeticInventory" then
            local proxy = {}
            if data then for k, v in pairs(data) do proxy[k] = v end end
            for skinName in pairs(unlockedSkins) do proxy[skinName] = true end
            return proxy
        end
        if weaponUnlockEnabled and not weaponUnlockSuspended and tostring(key):lower() == "weaponinventory" then
            local proxy = {}
            if type(data) == "table" then for k, v in pairs(data) do proxy[k] = v end end
            for _, name in ipairs(allWeapons) do
                if proxy[name] == nil then
                    proxy[name] = {Name=name, Owned=true, Unlocked=true, IsFavorited=false, XP=0, Level=1}
                end
            end
            return proxy
        end
        return data
    end

    -- Single GetWeaponData hook — skin merge only, never injects fake data
    local origGWD = DataController.GetWeaponData
    DataController.GetWeaponData = function(self, weaponName)
        local data = origGWD(self, weaponName)
        if data == nil then return nil end
        if not equipped[weaponName] then return data end
        local merged = {}
        for key, value in pairs(data) do merged[key] = value end
        pcall(setmetatable, merged, getmetatable(data))
        merged.Name = weaponName
        for cosmeticType, cosmeticData in pairs(equipped[weaponName]) do
            merged[cosmeticType] = cosmeticData
        end
        return merged
    end

    -- GetUnlockedWeapons — suspended during combat
    local origGUW = DataController.GetUnlockedWeapons
    if origGUW then
        DataController.GetUnlockedWeapons = function(self, ...)
            if not weaponUnlockEnabled or weaponUnlockSuspended then
                return origGUW(self, ...)
            end
            local result = {}
            for _, name in ipairs(allWeapons) do result[name] = true end
            return result
        end
    end

    if ClientItem and ClientItem._CreateViewModel then
        local origCVM = ClientItem._CreateViewModel
        ClientItem._CreateViewModel = function(self, viewmodelRef)
            local weaponName = self.Name
            local weaponPlayer = self.ClientFighter and self.ClientFighter.Player
            constructingWeapon = (weaponPlayer == player) and weaponName or nil
            if weaponPlayer == player and equipped[weaponName] and equipped[weaponName].Skin and viewmodelRef then
                pcall(function()
                    local dataKey = self:ToEnum("Data")
                    local skinKey = self:ToEnum("Skin")
                    local nameKey = self:ToEnum("Name")
                    if viewmodelRef[dataKey] then
                        viewmodelRef[dataKey][skinKey] = equipped[weaponName].Skin
                        viewmodelRef[dataKey][nameKey] = equipped[weaponName].Skin.Name
                    elseif viewmodelRef.Data then
                        viewmodelRef.Data.Skin = equipped[weaponName].Skin
                        viewmodelRef.Data.Name = equipped[weaponName].Skin.Name
                    end
                end)
            end
            local result = origCVM(self, viewmodelRef)
            constructingWeapon = nil
            return result
        end
    end

    local vmModule = player.PlayerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem:FindFirstChild("ClientViewModel")
    if vmModule then
        local VM = require(vmModule)
        if VM.GetWrap then
            local origGW = VM.GetWrap
            VM.GetWrap = function(self)
                local weaponName = self.ClientItem and self.ClientItem.Name
                local weaponPlayer = self.ClientItem and self.ClientItem.ClientFighter and self.ClientItem.ClientFighter.Player
                if weaponName and weaponPlayer == player and equipped[weaponName] and equipped[weaponName].Wrap then
                    return equipped[weaponName].Wrap
                end
                return origGW(self)
            end
        end
        local origNew = VM.new
        VM.new = function(replicatedData, clientItem)
            local weaponPlayer = clientItem.ClientFighter and clientItem.ClientFighter.Player
            local weaponName = constructingWeapon or clientItem.Name
            if weaponPlayer == player and equipped[weaponName] then
                pcall(function()
                    local RC = require(ReplicatedStorage.Modules.ReplicatedClass)
                    local dataKey = RC:ToEnum("Data")
                    replicatedData[dataKey] = replicatedData[dataKey] or {}
                    local c = equipped[weaponName]
                    if c.Skin then replicatedData[dataKey][RC:ToEnum("Skin")] = c.Skin end
                    if c.Wrap then replicatedData[dataKey][RC:ToEnum("Wrap")] = c.Wrap end
                    if c.Charm then replicatedData[dataKey][RC:ToEnum("Charm")] = c.Charm end
                end)
            end
            local result = origNew(replicatedData, clientItem)
            if weaponPlayer == player and equipped[weaponName] and equipped[weaponName].Wrap and result and result._UpdateWrap then
                pcall(function() result:_UpdateWrap() end)
                task.delay(0.1, function()
                    pcall(function() if not result._destroyed then result:_UpdateWrap() end end)
                end)
            end
            return result
        end
    end

    local origGVMI = ItemLibrary.GetViewModelImageFromWeaponData
    ItemLibrary.GetViewModelImageFromWeaponData = function(self, weaponData, highRes)
        if not weaponData then return origGVMI(self, weaponData, highRes) end
        local weaponName = weaponData.Name
        if equipped[weaponName] and equipped[weaponName].Skin then
            local skinInfo = self.ViewModels[equipped[weaponName].Skin.Name]
            if skinInfo then
                return skinInfo[highRes and "ImageHighResolution" or "Image"] or skinInfo.Image
            end
        end
        return origGVMI(self, weaponData, highRes)
    end

    if hookmetamethod then
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        local dataRemotes = remotes and remotes:FindFirstChild("Data")
        local equipRemote = dataRemotes and dataRemotes:FindFirstChild("EquipCosmetic")
        if equipRemote then
            local oldNC
            oldNC = hookmetamethod(game, "__namecall", function(self, ...)
                if self ~= equipRemote then return oldNC(self, ...) end
                if getnamecallmethod() ~= "FireServer" then return oldNC(self, ...) end
                local args = {...}
                local weaponName, cosmeticType, cosmeticName, options = args[1], args[2], args[3], args[4] or {}
                equipped[weaponName] = equipped[weaponName] or {}
                if not cosmeticName or cosmeticName == "None" or cosmeticName == "" then
                    equipped[weaponName][cosmeticType] = nil
                    if not next(equipped[weaponName]) then equipped[weaponName] = nil end
                elseif unlockedSkins[cosmeticName] then
                    local cloned = cloneCosmetic(cosmeticName, cosmeticType, {inverted = options.IsInverted})
                    if cloned then equipped[weaponName][cosmeticType] = cloned end
                else
                    return oldNC(self, ...)
                end
                Config.equippedSkins = Config.equippedSkins or {}
                if equipped[weaponName] then
                    Config.equippedSkins[weaponName] = Config.equippedSkins[weaponName] or {}
                    if cosmeticName and cosmeticName ~= "None" and cosmeticName ~= "" then
                        Config.equippedSkins[weaponName][cosmeticType] = cosmeticName
                    else
                        Config.equippedSkins[weaponName][cosmeticType] = nil
                    end
                else
                    Config.equippedSkins[weaponName] = nil
                end
                saveConfig()
                task.spawn(function()
                    task.wait()
                    pcall(function() DataController.CurrentData:Replicate("WeaponInventory") end)
                end)
                return
            end)
        end
    end

    print("✅ Patches applied.")
end

